# Azure OpenAI Configuration

# API Credentials
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_DEPLOYMENT_NAME=your_deployment_name
AZURE_MODEL_NAME=gpt-35-turbo

# Optional: API Version (default: 2024-02-15-preview)
# AZURE_API_VERSION=2024-02-15-preview

# Note: 
# - This file is used by APIClient.py for real API integration
# - By default, the demo uses mock responses (no API key needed)
# - To use the real API, fill in these values and they will be automatically loaded
# - Never commit this file with real credentials to version control
